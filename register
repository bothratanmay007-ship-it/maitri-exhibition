<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#225E63">
  <title>Maitri · Exhibition Registration</title>
  <style>
    :root {
      --teal:#225E63;
      --teal-2:#2B7379;
      --foam:#E8F2F1;
      --warm:#F7F3EA;
      --white:#FFFFFF;
      --ink:#33271B;
      --muted:#737B78;
      --line:#E3E8E5;
      --orange:#FF9700;
      --green:#15803D;
      --amber:#A16207;
      --red:#C81E1E;
    }

    * {
      box-sizing:border-box;
      margin:0;
      -webkit-tap-highlight-color:transparent;
    }

    html, body {
      min-height:100%;
      background:var(--warm);
      color:var(--ink);
      font-family:Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      -webkit-font-smoothing:antialiased;
    }

    body {
      padding-bottom:calc(28px + env(safe-area-inset-bottom));
    }

    button, input, select, textarea {
      font:inherit;
    }

    .topbar {
      position:sticky;
      top:0;
      z-index:30;
      min-height:62px;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:10px 16px;
      background:rgba(255,255,255,.97);
      border-bottom:1px solid var(--line);
      backdrop-filter:blur(12px);
    }

    .brand {
      display:flex;
      align-items:center;
      gap:10px;
    }

    .ekum {
      display:flex;
      align-items:center;
      gap:7px;
      color:var(--teal);
      font-size:14px;
      font-weight:800;
      letter-spacing:.11em;
    }

    .dot {
      width:11px;
      height:11px;
      border-radius:50%;
      background:var(--orange);
    }

    .divider {
      width:1px;
      height:28px;
      background:var(--line);
    }

    .maitri {
      display:block;
      width:92px;
      max-width:30vw;
      height:auto;
    }

    main {
      width:min(100%, 540px);
      margin:0 auto;
      padding:18px 15px 36px;
    }

    .hero {
      padding:20px;
      border-radius:18px;
      background:linear-gradient(135deg,var(--teal),#17494D);
      color:#fff;
      box-shadow:0 14px 32px rgba(34,94,99,.17);
    }

    .eyebrow {
      color:rgba(255,255,255,.72);
      font-size:10px;
      font-weight:800;
      letter-spacing:.08em;
      text-transform:uppercase;
    }

    .hero h1 {
      margin-top:6px;
      font-size:23px;
      line-height:1.18;
    }

    .hero p {
      margin-top:8px;
      color:rgba(255,255,255,.82);
      font-size:12px;
      line-height:1.55;
    }

    .card {
      margin-top:14px;
      padding:17px;
      border:1px solid var(--line);
      border-radius:15px;
      background:#fff;
      box-shadow:0 5px 18px rgba(34,94,99,.05);
    }

    .card h2 {
      color:var(--teal);
      font-size:15px;
    }

    .card-copy {
      margin-top:4px;
      color:var(--muted);
      font-size:11px;
      line-height:1.5;
    }

    label {
      display:block;
      margin:12px 0 5px;
      color:#4A514E;
      font-size:10px;
      font-weight:750;
      letter-spacing:.045em;
      text-transform:uppercase;
    }

    .required { color:var(--red); }
    .optional {
      color:var(--muted);
      font-weight:500;
      letter-spacing:0;
      text-transform:none;
    }

    input, select, textarea {
      width:100%;
      border:1px solid #DCE3DF;
      border-radius:10px;
      background:#fff;
      color:var(--ink);
      font-size:16px;
    }

    input, select {
      min-height:46px;
      padding:0 13px;
    }

    textarea {
      min-height:78px;
      padding:11px 13px;
      resize:vertical;
    }

    input:focus, select:focus, textarea:focus {
      outline:2px solid var(--teal-2);
      border-color:transparent;
    }

    .phone-row {
      display:flex;
      gap:8px;
    }

    .prefix {
      width:64px;
      min-width:64px;
      min-height:46px;
      display:flex;
      align-items:center;
      justify-content:center;
      border:1px solid #DCE3DF;
      border-radius:10px;
      background:var(--foam);
      color:var(--teal);
      font-size:14px;
      font-weight:800;
    }

    .btn {
      width:100%;
      min-height:48px;
      margin-top:14px;
      padding:0 14px;
      border:0;
      border-radius:10px;
      background:var(--teal);
      color:#fff;
      font-size:14px;
      font-weight:800;
      cursor:pointer;
      transition:transform .12s ease, opacity .12s ease;
    }

    .btn:active { transform:scale(.98); }
    .btn:disabled { opacity:.45; cursor:not-allowed; }

    .btn.secondary {
      border:1px solid var(--teal);
      background:#fff;
      color:var(--teal);
    }

    .btn.ghost {
      background:transparent;
      color:var(--muted);
    }

    .button-reason {
      min-height:17px;
      margin-top:6px;
      color:var(--muted);
      font-size:10px;
      text-align:center;
    }

    .agent-wrap {
      position:relative;
    }

    .agent-results {
      position:absolute;
      left:0;
      right:0;
      top:calc(100% + 5px);
      z-index:20;
      display:none;
      max-height:230px;
      overflow:auto;
      border:1px solid var(--line);
      border-radius:11px;
      background:#fff;
      box-shadow:0 14px 32px rgba(34,94,99,.15);
    }

    .agent-results.open { display:block; }

    .agent-option {
      width:100%;
      min-height:44px;
      display:flex;
      align-items:center;
      padding:9px 13px;
      border:0;
      border-bottom:1px solid var(--line);
      background:#fff;
      color:var(--ink);
      font-size:13px;
      text-align:left;
    }

    .agent-option:last-child { border-bottom:0; }
    .agent-option:active { background:var(--foam); }

    .agent-help {
      margin-top:5px;
      color:var(--muted);
      font-size:10px;
      line-height:1.4;
    }

    .privacy-note {
      display:flex;
      gap:9px;
      margin-top:12px;
      padding:11px 12px;
      border-radius:11px;
      background:var(--foam);
      color:var(--teal);
      font-size:10px;
      line-height:1.45;
    }

    .privacy-icon {
      width:24px;
      height:24px;
      min-width:24px;
      display:grid;
      place-items:center;
      border-radius:50%;
      background:#fff;
      font-weight:900;
    }

    .find-card summary {
      cursor:pointer;
      color:var(--teal);
      font-size:13px;
      font-weight:800;
      list-style:none;
    }

    .find-card summary::-webkit-details-marker { display:none; }

    .find-card summary:after {
      content:"+";
      float:right;
      font-size:18px;
      font-weight:500;
    }

    .find-card[open] summary:after { content:"−"; }

    .status-screen {
      display:none;
    }

    .status-screen.open {
      display:block;
      animation:screenIn .25s ease both;
    }

    .registration-screen.hidden {
      display:none;
    }

    @keyframes screenIn {
      from { opacity:0; transform:translateY(7px); }
      to { opacity:1; transform:translateY(0); }
    }

    .status-card {
      margin-top:14px;
      padding:22px 18px;
      border:1px solid var(--line);
      border-radius:18px;
      background:#fff;
      text-align:center;
      box-shadow:0 12px 28px rgba(34,94,99,.09);
    }

    .status-icon {
      width:58px;
      height:58px;
      display:grid;
      place-items:center;
      margin:0 auto 12px;
      border-radius:50%;
      background:var(--foam);
      color:var(--teal);
      font-size:26px;
      font-weight:900;
    }

    .status-label {
      color:var(--muted);
      font-size:10px;
      font-weight:800;
      letter-spacing:.08em;
      text-transform:uppercase;
    }

    .queue-number {
      margin-top:3px;
      color:var(--teal);
      font-size:27px;
      font-weight:900;
    }

    .party-name {
      margin-top:4px;
      color:var(--ink);
      font-size:14px;
      font-weight:800;
    }

    .position-grid {
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
      margin-top:16px;
    }

    .position-box {
      padding:13px 8px;
      border-radius:12px;
      background:#F7FAF9;
      border:1px solid var(--line);
    }

    .position-box b {
      display:block;
      color:var(--teal);
      font-size:22px;
    }

    .position-box span {
      display:block;
      margin-top:2px;
      color:var(--muted);
      font-size:10px;
    }

    .status-message {
      margin-top:14px;
      padding:12px;
      border-radius:11px;
      background:var(--foam);
      color:var(--teal);
      font-size:12px;
      font-weight:750;
      line-height:1.5;
    }

    .status-message.accepted {
      background:#DCFCE7;
      color:#166534;
    }

    .status-message.removed {
      background:#FEE2E2;
      color:#991B1B;
    }

    .last-check {
      margin-top:9px;
      color:var(--muted);
      font-size:10px;
    }

    .loading {
      display:none;
      position:fixed;
      inset:0;
      z-index:80;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:rgba(23,32,30,.46);
    }

    .loading.open { display:flex; }

    .loading-card {
      width:100%;
      max-width:330px;
      padding:22px;
      border-radius:16px;
      background:#fff;
      text-align:center;
    }

    .spinner {
      width:30px;
      height:30px;
      margin:0 auto 10px;
      border:3px solid var(--foam);
      border-top-color:var(--teal);
      border-radius:50%;
      animation:spin .8s linear infinite;
    }

    @keyframes spin { to { transform:rotate(360deg); } }

    .modal {
      position:fixed;
      inset:0;
      z-index:100;
      display:flex;
      align-items:flex-end;
      justify-content:center;
      padding:0;
      background:rgba(20,26,25,.46);
      opacity:0;
      visibility:hidden;
      transition:opacity .2s ease, visibility .2s ease;
    }

    .modal.open {
      opacity:1;
      visibility:visible;
    }

    .modal-sheet {
      width:100%;
      max-width:540px;
      padding:22px 18px calc(20px + env(safe-area-inset-bottom));
      border-radius:20px 20px 0 0;
      background:#fff;
      transform:translateY(105%);
      transition:transform .27s cubic-bezier(.2,.86,.25,1);
    }

    .modal.open .modal-sheet { transform:translateY(0); }

    .modal-icon {
      width:50px;
      height:50px;
      display:grid;
      place-items:center;
      margin:0 auto 11px;
      border-radius:50%;
      background:var(--foam);
      color:var(--teal);
      font-size:23px;
      font-weight:900;
    }

    .modal-sheet.error .modal-icon {
      background:#FEE2E2;
      color:var(--red);
    }

    .modal-sheet.success .modal-icon {
      background:#DCFCE7;
      color:var(--green);
    }

    .modal-title {
      font-size:17px;
      font-weight:850;
      text-align:center;
    }

    .modal-message {
      margin-top:7px;
      color:var(--muted);
      font-size:12px;
      line-height:1.55;
      text-align:center;
      white-space:pre-line;
    }

    .modal-actions {
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:9px;
      margin-top:18px;
    }

    .modal-actions.single {
      grid-template-columns:1fr;
    }

    .modal-actions .btn {
      margin:0;
    }

    @media (min-width:650px) {
      .modal {
        align-items:center;
        padding:18px;
      }

      .modal-sheet {
        border-radius:20px;
        transform:translateY(20px) scale(.98);
      }

      .modal.open .modal-sheet {
        transform:translateY(0) scale(1);
      }
    }
  </style>
</head>

<body>
  <header class="topbar">
    <div class="brand">
      <span class="ekum"><i class="dot"></i>EKUM</span>
      <span class="divider"></span>
      <img class="maitri" src="data:image/png;base64," alt="Maitri">
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="eyebrow">CMAI Exhibition</div>
      <h1>Register before your turn</h1>
      <p>Enter your details once. You will receive a queue number and can check your live position from this phone.</p>
    </section>

    <div class="registration-screen" id="registration-screen">
      <section class="card">
        <h2>Party Registration</h2>
        <div class="card-copy">Fields marked with * are required.</div>

        <label>Company / Firm name <span class="required">*</span></label>
        <input id="c-name" autocomplete="organization">

        <label>Contact person <span class="required">*</span></label>
        <input id="c-contact" autocomplete="name">

        <label>Mobile number <span class="required">*</span></label>
        <div class="phone-row">
          <span class="prefix">+91</span>
          <input id="c-phone" inputmode="numeric" maxlength="10" autocomplete="tel">
        </div>

        <label>Agent <span class="optional">(optional)</span></label>
        <div class="agent-wrap">
          <input id="c-agent" autocomplete="off" placeholder="Start typing agent name…">
          <div class="agent-results" id="agent-results"></div>
        </div>
        <div class="agent-help">The full agent list is not shown. Matching names appear only after you type.</div>

        <label>City <span class="required">*</span></label>
        <input id="c-city" autocomplete="address-level2">

        <label>State <span class="optional">(optional)</span></label>
        <select id="c-state"></select>

        <label>GSTIN <span class="optional">(optional)</span></label>
        <input id="c-gstin" maxlength="15" autocomplete="off" style="text-transform:uppercase">

        <label>Notes <span class="optional">(optional)</span></label>
        <textarea id="c-notes"></textarea>

        <button class="btn" id="join-button" onclick="confirmJoinQueue()" disabled>Join Reception Queue</button>
        <div class="button-reason" id="join-reason">Enter firm name, contact person, mobile number and city</div>

        <div class="privacy-note">
          <span class="privacy-icon">✓</span>
          <span>Your position is private. This page never displays other party names or customer details.</span>
        </div>
      </section>

      <details class="card find-card" id="find-card">
        <summary>Already registered? Find my place</summary>
        <div class="card-copy">Use the exact firm name and mobile number entered during registration.</div>

        <label>Company / Firm name</label>
        <input id="f-name" autocomplete="organization">

        <label>Mobile number</label>
        <div class="phone-row">
          <span class="prefix">+91</span>
          <input id="f-phone" inputmode="numeric" maxlength="10" autocomplete="tel">
        </div>

        <button class="btn secondary" onclick="findMyRegistration()">Find My Queue Position</button>
      </details>
    </div>

    <div class="status-screen" id="status-screen">
      <section class="status-card">
        <div class="status-icon" id="status-icon">✓</div>
        <div class="status-label">Your queue number</div>
        <div class="queue-number" id="status-number">Q-000</div>
        <div class="party-name" id="status-party"></div>

        <div class="position-grid" id="position-grid">
          <div class="position-box">
            <b id="status-position">—</b>
            <span>Current position</span>
          </div>
          <div class="position-box">
            <b id="status-ahead">—</b>
            <span>Parties ahead</span>
          </div>
        </div>

        <div class="status-message" id="status-message"></div>
        <div class="last-check" id="status-last-check"></div>

        <button class="btn" onclick="refreshMyStatus(true)">Refresh Position</button>
        <button class="btn ghost" onclick="clearQueueSession()">Use another registration</button>

        <div class="privacy-note">
          <span class="privacy-icon">i</span>
          <span>You may close this page and return later on the same phone. Your private queue access is saved on this device.</span>
        </div>
      </section>
    </div>
  </main>

  <div class="loading" id="loading">
    <div class="loading-card">
      <div class="spinner"></div>
      <b id="loading-title">Please wait…</b>
      <div class="card-copy" id="loading-copy"></div>
    </div>
  </div>

  <div class="modal" id="modal" onclick="modalBackdrop(event)">
    <div class="modal-sheet" id="modal-sheet">
      <div class="modal-icon" id="modal-icon">i</div>
      <div class="modal-title" id="modal-title"></div>
      <div class="modal-message" id="modal-message"></div>
      <div class="modal-actions" id="modal-actions">
        <button class="btn secondary" id="modal-cancel" onclick="closeModal(false)">Cancel</button>
        <button class="btn" id="modal-confirm" onclick="closeModal(true)">Continue</button>
      </div>
    </div>
  </div>

  <script>
    const API_URL = 'https://script.google.com/macros/s/AKfycbylfA7EoANdu_99zFWr2NsrX-EjvLmpKk5_Ws5qXhJ6KK-KAiu_1BZbPLe5x95u-gkR/exec';
    const SESSION_KEY = 'cmai_customer_queue_session';
    const STATES = [
      'Andaman & Nicobar','Andhra Pradesh','Arunachal Pradesh','Assam','Bihar',
      'Chandigarh','Chhattisgarh','Dadra & Nagar Haveli and Daman & Diu','Delhi',
      'Goa','Gujarat','Haryana','Himachal Pradesh','Jammu & Kashmir','Jharkhand',
      'Karnataka','Kerala','Ladakh','Lakshadweep','Madhya Pradesh','Maharashtra',
      'Manipur','Meghalaya','Mizoram','Nagaland','Odisha','Puducherry','Punjab',
      'Rajasthan','Sikkim','Tamil Nadu','Telangana','Tripura','Uttar Pradesh',
      'Uttarakhand','West Bengal'
    ];

    let selectedAgent = '';
    let agentTimer = null;
    let statusTimer = null;
    let modalResolver = null;
    let modalDismissible = true;

    function el(id) {
      return document.getElementById(id);
    }

    function value(id) {
      return el(id).value.trim();
    }

    function escapeHtml(input) {
      return String(input == null ? '' : input)
        .replace(/&/g,'&amp;')
        .replace(/</g,'&lt;')
        .replace(/>/g,'&gt;')
        .replace(/"/g,'&quot;')
        .replace(/'/g,'&#039;');
    }

    function api(fn, args) {
      return fetch(API_URL, {
        method:'POST',
        body:JSON.stringify({ fn, args:args || [] })
      })
      .then(response => response.json())
      .then(json => {
        if (!json.ok) throw new Error(json.error || 'Server error');
        return json.data;
      });
    }

    function showLoading(title, copy) {
      el('loading-title').textContent = title || 'Please wait…';
      el('loading-copy').textContent = copy || '';
      el('loading').classList.add('open');
    }

    function hideLoading() {
      el('loading').classList.remove('open');
    }

    function haptic(pattern) {
      if (navigator.vibrate) navigator.vibrate(pattern || 30);
    }

    function openModal(options) {
      options = options || {};
      const type = options.type || 'info';
      const showCancel = !!options.cancelText;

      el('modal-sheet').className = 'modal-sheet ' + type;
      el('modal-icon').textContent =
        type === 'success' ? '✓' : (type === 'error' ? '×' : 'i');
      el('modal-title').textContent = options.title || 'Information';
      el('modal-message').textContent = options.message || '';
      el('modal-cancel').textContent = options.cancelText || 'Cancel';
      el('modal-confirm').textContent = options.confirmText || 'Continue';
      el('modal-cancel').style.display = showCancel ? 'block' : 'none';
      el('modal-actions').classList.toggle('single', !showCancel);
      modalDismissible = options.dismissible !== false;
      el('modal').classList.add('open');
      haptic(type === 'error' ? [45,35,45] : 25);

      return new Promise(resolve => {
        modalResolver = resolve;
      });
    }

    function closeModal(result) {
      el('modal').classList.remove('open');
      const resolver = modalResolver;
      modalResolver = null;
      setTimeout(() => { if (resolver) resolver(!!result); }, 170);
    }

    function modalBackdrop(event) {
      if (event.target === el('modal') && modalDismissible) closeModal(false);
    }

    function updateJoinState() {
      const valid =
        !!value('c-name') &&
        !!value('c-contact') &&
        /^\d{10}$/.test(value('c-phone')) &&
        !!value('c-city');

      el('join-button').disabled = !valid;
      el('join-reason').textContent = valid
        ? ''
        : 'Enter firm name, contact person, mobile number and city';
    }

    function closeAgentResults() {
      el('agent-results').classList.remove('open');
    }

    function renderAgentResults(results) {
      const box = el('agent-results');

      if (!results.length) {
        box.innerHTML = '<div class="agent-option" style="color:var(--muted)">No matching agent</div>';
      } else {
        box.innerHTML = results.map(name =>
          '<button type="button" class="agent-option" data-agent="' +
          escapeHtml(name) + '">' + escapeHtml(name) + '</button>'
        ).join('');

        box.querySelectorAll('[data-agent]').forEach(button => {
          button.addEventListener('click', () => {
            selectedAgent = button.dataset.agent;
            el('c-agent').value = selectedAgent;
            closeAgentResults();
          });
        });
      }

      box.classList.add('open');
    }

    function searchAgents() {
      const query = value('c-agent');
      selectedAgent = '';

      clearTimeout(agentTimer);
      if (query.length < 2) {
        closeAgentResults();
        return;
      }

      agentTimer = setTimeout(() => {
        api('searchQueueAgents', [query])
          .then(renderAgentResults)
          .catch(() => closeAgentResults());
      }, 260);
    }

    function registrationPayload() {
      const agentText = value('c-agent');
      if (agentText && !selectedAgent) {
        throw new Error('Select the agent from the matching suggestions');
      }

      return {
        name:value('c-name'),
        contact:value('c-contact'),
        phone:value('c-phone'),
        agent:selectedAgent || '',
        city:value('c-city'),
        state:el('c-state').value || '',
        gstin:value('c-gstin').toUpperCase(),
        notes:value('c-notes')
      };
    }

    async function confirmJoinQueue() {
      let payload;
      try {
        payload = registrationPayload();
      } catch (error) {
        await openModal({
          type:'error',
          title:'Check the registration',
          message:error.message,
          confirmText:'Dismiss'
        });
        return;
      }

      const confirmed = await openModal({
        type:'info',
        title:'Join the reception queue?',
        message:'Register ' + payload.name + ' and receive a live queue number?',
        confirmText:'Join Queue',
        cancelText:'Review'
      });

      if (!confirmed) return;
      joinQueue(payload);
    }

    function joinQueue(payload) {
      showLoading('Joining Queue…', 'Your queue number is being created using the reception server time.');

      api('joinReceptionQueue', [payload])
        .then(status => {
          hideLoading();
          saveQueueSession(status);
          showStatus(status);
          openModal({
            type:'success',
            title:'Registration received',
            message:'Your queue number is ' + status.queueNumber + '. You can refresh this page or return later on the same phone.',
            confirmText:'View Position'
          });
        })
        .catch(async error => {
          hideLoading();
          await openModal({
            type:'error',
            title:'Registration could not be completed',
            message:error.message,
            confirmText:'Dismiss'
          });
        });
    }

    function saveQueueSession(status) {
      const current = loadQueueSession() || {};
      const session = {
        queueId:status.queueId || current.queueId,
        accessToken:status.accessToken || current.accessToken
      };

      try {
        localStorage.setItem(SESSION_KEY, JSON.stringify(session));
      } catch (error) {}
    }

    function loadQueueSession() {
      try {
        return JSON.parse(localStorage.getItem(SESSION_KEY) || 'null');
      } catch (error) {
        return null;
      }
    }

    function showRegistration() {
      el('registration-screen').classList.remove('hidden');
      el('status-screen').classList.remove('open');
      if (statusTimer) clearInterval(statusTimer);
      statusTimer = null;
    }

    function showStatus(status) {
      el('registration-screen').classList.add('hidden');
      el('status-screen').classList.add('open');
      el('status-number').textContent = status.queueNumber || '';
      el('status-party').textContent = status.partyName || '';
      el('status-position').textContent = status.position || '—';
      el('status-ahead').textContent =
        status.status === 'Waiting' ? Number(status.ahead || 0) : '—';
      el('status-message').textContent = status.message || '';
      el('status-message').className =
        'status-message ' + String(status.status || '').toLowerCase();
      el('status-last-check').textContent =
        'Last checked at ' + new Date().toLocaleTimeString([], {
          hour:'2-digit',
          minute:'2-digit'
        });

      if (status.status === 'Accepted') {
        el('status-icon').textContent = '✓';
        el('status-icon').style.background = '#DCFCE7';
        el('status-icon').style.color = '#166534';
        el('position-grid').style.display = 'none';
        haptic([60,40,60]);
      } else if (status.status === 'Removed') {
        el('status-icon').textContent = '!';
        el('status-icon').style.background = '#FEE2E2';
        el('status-icon').style.color = '#991B1B';
        el('position-grid').style.display = 'none';
      } else {
        el('status-icon').textContent = status.position === 1 ? '1' : '⌛';
        el('status-icon').style.background = 'var(--foam)';
        el('status-icon').style.color = 'var(--teal)';
        el('position-grid').style.display = 'grid';
      }

      if (statusTimer) clearInterval(statusTimer);
      if (status.status === 'Waiting') {
        statusTimer = setInterval(() => refreshMyStatus(false), 15000);
      }
    }

    function refreshMyStatus(showOverlay) {
      const session = loadQueueSession();
      if (!session || !session.queueId || !session.accessToken) {
        showRegistration();
        return;
      }

      if (showOverlay) {
        showLoading('Refreshing Position…', 'Checking the live reception queue.');
      }

      api('getMyQueueStatus', [session])
        .then(status => {
          if (showOverlay) hideLoading();
          showStatus(status);
        })
        .catch(async error => {
          if (showOverlay) hideLoading();
          if (statusTimer) clearInterval(statusTimer);
          statusTimer = null;

          await openModal({
            type:'error',
            title:'Queue position could not be loaded',
            message:error.message,
            confirmText:'Find Registration'
          });

          showRegistration();
          el('find-card').open = true;
        });
    }

    function findMyRegistration() {
      const name = value('f-name');
      const phone = value('f-phone');

      if (name.length < 3 || !/^\d{10}$/.test(phone)) {
        openModal({
          type:'error',
          title:'Enter the same registration details',
          message:'Enter the full firm name and the exact 10-digit mobile number used during registration.',
          confirmText:'Dismiss'
        });
        return;
      }

      showLoading('Finding Registration…', 'Only an exact firm name and mobile match can be opened.');

      api('findMyQueueRegistration', [{
        partyName:name,
        phone
      }])
      .then(status => {
        hideLoading();
        saveQueueSession(status);
        showStatus(status);
      })
      .catch(async error => {
        hideLoading();
        await openModal({
          type:'error',
          title:'Registration not found',
          message:error.message + '. Check the spelling and mobile number, or contact reception.',
          confirmText:'Dismiss'
        });
      });
    }

    async function clearQueueSession() {
      const confirmed = await openModal({
        type:'info',
        title:'Use another registration?',
        message:'This will remove the saved queue access from this phone.',
        confirmText:'Continue',
        cancelText:'Cancel'
      });

      if (!confirmed) return;

      try {
        localStorage.removeItem(SESSION_KEY);
      } catch (error) {}

      showRegistration();
    }

    document.addEventListener('click', event => {
      if (!event.target.closest('.agent-wrap')) closeAgentResults();
    });

    (function init() {
      el('c-state').innerHTML =
        '<option value="">Select state</option>' +
        STATES.map(state =>
          '<option value="' + state + '">' + state + '</option>'
        ).join('');

      ['c-name','c-contact','c-phone','c-city'].forEach(id => {
        el(id).addEventListener('input', updateJoinState);
      });

      el('c-agent').addEventListener('input', searchAgents);
      el('c-agent').addEventListener('focus', searchAgents);

      updateJoinState();

      const session = loadQueueSession();
      if (session && session.queueId && session.accessToken) {
        refreshMyStatus(true);
      } else {
        showRegistration();
      }
    })();
  </script>
</body>
</html>
